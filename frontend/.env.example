# ─── ECHO Environment Configuration ───────────────────
# Copy this file to .env.local and adjust for your environment.
# Never commit real credentials.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Data adapter: "mock" for local development, "http" for production
NEXT_PUBLIC_DATA_ADAPTER=mock

# Feature flags
NEXT_PUBLIC_ENABLE_BUDDY=true
NEXT_PUBLIC_ENABLE_FACIAL_ANALYSIS=true
NEXT_PUBLIC_ENABLE_RISK_INSIGHTS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_DATA_EXPORT=true
